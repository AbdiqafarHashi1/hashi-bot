{
  "name": "hashi-bot",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:worker": "pnpm --filter ./apps/worker dev",
    "verify:env": "node ./scripts/verify-env.mjs --target=all --mode=development --worker-mode=paper --venue=mock",
    "bootstrap:local": "node ./scripts/bootstrap-local.mjs",
    "test": "turbo run test",
    "verify:migrations": "node ./scripts/verify-migrations-readiness.mjs",
    "verify:dataset": "node ./scripts/verify-dataset-sanity.mjs",
    "smoke:backtest": "node ./scripts/smoke-backtest.mjs",
    "smoke:replay": "node ./scripts/smoke-replay.mjs",
    "smoke:live:mock": "node ./scripts/smoke-live-mock.mjs",
    "verify:release": "node ./scripts/verify-release-readiness.mjs",
    "verify:env:web:prod": "node ./scripts/verify-env.mjs --target=web --mode=production",
    "verify:env:worker:paper": "node ./scripts/verify-env.mjs --target=worker --mode=development --worker-mode=paper",
    "verify:env:worker:live": "node ./scripts/verify-env.mjs --target=worker --mode=production --worker-mode=live"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv": "^17.3.1",
    "tsx": "^4.19.2",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
