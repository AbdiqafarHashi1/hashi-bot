{
  "name": "hashi-bot",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:worker": "pnpm --filter ./apps/worker dev",
    "verify:env": "node ./scripts/verify-env.mjs",
    "bootstrap:local": "node ./scripts/bootstrap-local.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
