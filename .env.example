# ------------------------------------------------------------
# Shared runtime identity
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=hashi-bot

# ------------------------------------------------------------
# Web deployment (required in production web app)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Worker + storage baseline
# ------------------------------------------------------------
WORKER_MODE=evaluation
EXECUTION_VENUE=mock
LIVE_ACCOUNT_REF=paper-account
LIVE_ENGINE_ENABLED=false
DATABASE_URL=
REDIS_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Optional safety/alert integrations
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# CCXT adapter credentials (required when EXECUTION_VENUE=ccxt)
# ------------------------------------------------------------
CCXT_EXCHANGE_ID=binance
CCXT_API_KEY=
CCXT_API_SECRET=
CCXT_API_PASSWORD=
CCXT_MARKET_TYPE=spot
CCXT_SANDBOX=true

# ------------------------------------------------------------
# cTrader adapter credentials (required when EXECUTION_VENUE=ctrader)
# ------------------------------------------------------------
CTRADER_BASE_URL=http://localhost:8080
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=

# ------------------------------------------------------------
# Worker mode specific controls
# ------------------------------------------------------------
DATASET_ID=dataset-btc-1m
REPLAY_DATASET_ID=dataset-btc-1m
DATASET_CSV_PATH=
DATASET_SYMBOL_CODE=ETHUSDT
DATASET_TIMEFRAME=15m
REPLAY_SYMBOLS=BTCUSDT
REPLAY_ACTION=step
REPLAY_STEPS=1
LIVE_ENABLED=false
LIVE_MAX_CYCLES=1
LIVE_CYCLE_DELAY_MS=0
LIVE_STALE_AFTER_MS=60000
WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT
RANKING_LIMIT=5
